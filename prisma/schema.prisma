
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Change to "mysql" if using MySQL
  url      = env("DATABASE_URL")
}

model ManagedUser {
  id        String   @id @default(cuid())
  username  String   @unique
  fullName  String
  email     String   @unique
  password  String   @default("password123")
  role      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model MalariaCase {
  id            String   @id
  patientName   String
  age           Int
  gender        String
  symptoms      String   // Comma-separated string
  testResult    String
  latitude      Float
  longitude     Float
  area          String
  status        String
  treatment     String?
  reportedBy    String
  reportedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contactNumber String?
}
